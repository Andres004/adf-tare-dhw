{
	"name": "DF_Gold_Rango",
	"properties": {
		"folder": {
			"name": "Gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Silver_Rangos",
						"type": "DatasetReference"
					},
					"name": "SilverRangos"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Gold_Dim_Rango",
						"type": "DatasetReference"
					},
					"name": "GoldRangos"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          id_rango_origen as integer,",
				"          nombre as string,",
				"          categoria as string,",
				"          nivel_jerarquico as integer,",
				"          abreviatura as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     batchSize: 0,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    id_rango AS id_rango_origen,\\n    nombre,\\n    categoria,\\n    nivel_jerarquico,\\n    abreviatura\\nFROM silver.rangos',",
				"     format: 'query') ~> SilverRangos",
				"SilverRangos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          rango_key as integer,",
				"          id_rango_origen as integer,",
				"          nombre as string,",
				"          categoria as string,",
				"          nivel_jerarquico as integer,",
				"          abreviatura as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_rango_origen,",
				"          nombre,",
				"          categoria,",
				"          nivel_jerarquico,",
				"          abreviatura",
				"     )) ~> GoldRangos"
			]
		}
	}
}