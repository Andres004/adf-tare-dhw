{
	"name": "DF_Tipo_Operacion",
	"properties": {
		"folder": {
			"name": "Gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Silver_Tipos_Operaciones",
						"type": "DatasetReference"
					},
					"name": "SilverTipoOperacion"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Gold_Dim_Tipo_Operacion",
						"type": "DatasetReference"
					},
					"name": "GoldTipoOperacion"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          id_tipo_origen as integer,",
				"          nombre as string,",
				"          categoria as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    id_tipo AS id_tipo_origen,\\n    nombre,\\n    categoria\\nFROM silver.tipos_operacion',",
				"     format: 'query') ~> SilverTipoOperacion",
				"SilverTipoOperacion sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          tipo_op_key as integer,",
				"          id_tipo_origen as integer,",
				"          nombre as string,",
				"          categoria as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_tipo_origen,",
				"          nombre,",
				"          categoria",
				"     )) ~> GoldTipoOperacion"
			]
		}
	}
}