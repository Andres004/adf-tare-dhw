{
	"name": "DF_Tipo_Movimiento",
	"properties": {
		"folder": {
			"name": "Gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Silver_Tipos_Movimientos",
						"type": "DatasetReference"
					},
					"name": "SilverTIpoMovimiento"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Gold_Dim_Tipo_Movimiento",
						"type": "DatasetReference"
					},
					"name": "GoldTipoMovimineto"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          id_tipo_origen as integer,",
				"          nombre as string,",
				"          descripcion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    id_tipo AS id_tipo_origen,\\n    nombre,\\n    descripcion\\nFROM silver.tipos_movimiento',",
				"     format: 'query') ~> SilverTIpoMovimiento",
				"SilverTIpoMovimiento sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          tipo_mov_key as integer,",
				"          id_tipo_origen as integer,",
				"          nombre as string,",
				"          descripcion as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_tipo_origen,",
				"          nombre,",
				"          descripcion",
				"     )) ~> GoldTipoMovimineto"
			]
		}
	}
}