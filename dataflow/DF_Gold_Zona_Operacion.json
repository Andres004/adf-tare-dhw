{
	"name": "DF_Gold_Zona_Operacion",
	"properties": {
		"folder": {
			"name": "Gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Silver_Zonas",
						"type": "DatasetReference"
					},
					"name": "SilverZonaOperacion"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Gold_Dim_Zona_Operacion",
						"type": "DatasetReference"
					},
					"name": "GoldZonaOperacion"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          id_zona_origen as integer,",
				"          nombre as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          altitud_msnm as integer,",
				"          acceso_carretero as string,",
				"          nivel_riesgo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    id_zona AS id_zona_origen,\\n    nombre,\\n    departamento,\\n    frontera_con,\\n    tipo_terreno,\\n    altitud_msnm,\\n    acceso_carretero,\\n    nivel_riesgo\\nFROM silver.zonas',",
				"     format: 'query') ~> SilverZonaOperacion",
				"SilverZonaOperacion sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          zona_key as integer,",
				"          id_zona_origen as integer,",
				"          nombre as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          altitud_msnm as integer,",
				"          acceso_carretero as string,",
				"          nivel_riesgo as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_zona_origen,",
				"          nombre,",
				"          departamento,",
				"          frontera_con,",
				"          tipo_terreno,",
				"          altitud_msnm,",
				"          acceso_carretero,",
				"          nivel_riesgo",
				"     )) ~> GoldZonaOperacion"
			]
		}
	}
}